---
import { footerContent, type Locale } from "../lib/siteContent";
import { localeLinks, footerCopy } from '../lib/siteContent';
const currentYear = new Date().getFullYear();
const { locale = 'es' } = Astro.props;
const localeKey: keyof typeof localeLinks = locale === 'en' ? 'en' : 'es';
const links = localeLinks[localeKey].footer;
const copy = footerCopy[localeKey];
const footer = footerContent[localeKey];
const homeHref = localeKey === 'en' ? '/en' : '/';
---

<footer class="bg-[#0B2C4A] px-4 pb-6 pt-20 text-white md:px-6 md:pt-28">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-12 border-t border-white/15 pt-8 md:grid-cols-[1fr_auto] md:items-start">

      <div class="flex flex-col items-start">
        <!-- FIX: tagline con opacidad /75 para jerarquía — destacar sin competir con el wordmark -->
        <p class="max-w-sm text-lg font-medium text-white/75">
          {footer.tagline}
        </p>

        <div class="mt-5 flex items-center gap-4">
          <!-- FIX: touch targets explícitos h-10 w-10 en iconos sociales -->
          <a
            href="https://linkedin.com/company/vidra"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={footer.social.linkedinLabel}
            class="flex h-10 w-10 items-center justify-center rounded-full border border-white/15 text-white/55 transition hover:border-white/30 hover:text-white"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 640 640"
              fill="currentColor"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path d="M160 96C124.7 96 96 124.7 96 160L96 480C96 515.3 124.7 544 160 544L480 544C515.3 544 544 515.3 544 480L544 160C544 124.7 515.3 96 480 96L160 96zM165 266.2L231.5 266.2L231.5 480L165 480L165 266.2zM236.7 198.5C236.7 219.8 219.5 237 198.2 237C176.9 237 159.7 219.8 159.7 198.5C159.7 177.2 176.9 160 198.2 160C219.5 160 236.7 177.2 236.7 198.5zM413.9 480L413.9 376C413.9 351.2 413.4 319.3 379.4 319.3C344.8 319.3 339.5 346.3 339.5 374.2L339.5 480L273.1 480L273.1 266.2L336.8 266.2L336.8 295.4L337.7 295.4C346.6 278.6 368.3 260.9 400.6 260.9C467.8 260.9 480.3 305.2 480.3 362.8L480.3 480L413.9 480z"/>
            </svg>
          </a>

          <a
            href="https://instagram.com/vidra"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={footer.social.instagramLabel}
            class="flex h-10 w-10 items-center justify-center rounded-full border border-white/15 text-white/55 transition hover:border-white/30 hover:text-white"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path d="M7 2C4.24 2 2 4.24 2 7v10c0 2.76 2.24 5 5 5h10c2.76 0 5-2.24 5-5V7c0-2.76-2.24-5-5-5H7zm0 2h10c1.65 0 3 1.35 3 3v10c0 1.65-1.35 3-3 3H7c-1.65 0-3-1.35-3-3V7c0-1.65 1.35-3 3-3zm10.5 1.5a1 1 0 1 0 0 2 1 1 0 0 0 0-2zM12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm0 2a3 3 0 1 1 0 6 3 3 0 0 1 0-6z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- FIX: nav links con opacidad /55 (tertiary) y texto más legible en hover -->
      <nav class="grid gap-3 text-sm font-medium md:text-right">
        {links.map((link: { label: string; href: string }) => (
          <a href={link.href} class="text-white/55 transition hover:text-white">
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <!-- Wordmark — sin cambios, es el elemento de marca -->
    <div class="mt-20 md:mt-28">
      <h2 class="text-[clamp(4rem,16vw,10rem)] font-medium leading-[0.78] tracking-[-0.08em] text-white">
        <span>Vidra</span><span class="text-[#00B2EB]">IA</span>
      </h2>
    </div>

    <!-- FIX: opacidad /45 mantenida para el legal — es tertiary en contexto de footer bottom -->
    <div class="mt-8 flex flex-col gap-3 border-t border-white/15 pt-5 text-xs text-white/45 md:flex-row md:items-center md:justify-between">
      <p>{copy.yearLabel.replace('{year}', String(currentYear))}</p>
      <p>{copy.tagline}</p>
      <a href="/legal" class="transition hover:text-white/75">{copy.legal}</a>
    </div>
  </div>
</footer>