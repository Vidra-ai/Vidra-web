---
const phases = [
  {
    number: '01',
    label: 'Fase 01 · Identificar',
    title: 'Identificar',
    text: 'Entrevistamos a tu equipo, mapeamos cada proceso ineficiente y calculamos su coste real: personas, horas, coste/hora, errores y oportunidad perdida. Te entregamos un número claro antes de invertir.',
    badge: 'Resultado en 2-3 semanas.',
  },
  {
    number: '02',
    label: 'Fase 02 · Construir',
    title: 'Construir',
    text: 'Diseñamos y desarrollamos soluciones de IA integradas en tus sistemas actuales. Sin migraciones innecesarias. Sin disrupciones. En producción, no en demo.',
    badge: 'Primer piloto en semanas.',
  },
  {
    number: '03',
    label: 'Fase 03 · Adoptar',
    title: 'Adoptar',
    text: 'Formamos a tu equipo para que use, supervise y mejore las soluciones sin depender de nosotros para cada cambio. Acompañamos hasta que la IA forme parte del trabajo diario.',
    badge: 'Autonomía desde el mes 1.',
  },
  {
    number: '04',
    label: 'Fase 04 · Evolucionar',
    title: 'Evolucionar',
    text: 'Revisamos resultados, optimizamos flujos y detectamos nuevas oportunidades. Tu negocio cambia, tus soluciones de IA evolucionan con él.',
    badge: 'Acompañamiento continuo.',
  },
];
---

<section id="process" class="relative overflow-hidden bg-white px-4 py-20 md:px-6 md:py-28">
  <div class="mx-auto max-w-5xl">
    <div class="mb-16 max-w-2xl md:mb-20">
      <p class="mb-5 text-[11px] font-semibold uppercase tracking-[0.25em] text-[#0B2C4A]/70 md:text-xs">
        Cómo trabajamos
      </p>

      <h2 class="text-2xl font-medium leading-[1.15] tracking-[-0.04em] text-[#071729] md:text-3xl lg:text-4xl">
        Implementamos IA en tu empresa
        <span class="text-[#0B2C4A]">en cuatro fases.</span>
      </h2>
    </div>

    <div class="relative grid grid-cols-1 gap-0 md:grid-cols-[60px_1fr]">
      <div class="relative hidden md:block">
        <div class="absolute left-[30px] top-9 h-[calc(100%-4.5rem)] w-px bg-[#071729]/15"></div>

        <div
          id="process-progress"
          class="absolute left-[30px] top-9 h-0 w-px bg-[#0B2C4A]/80 transition-[height] duration-150"
        ></div>

        {
          phases.map((_, index) => (
            <div
              class="absolute left-[30px] z-10 -translate-x-1/2 -translate-y-1/2"
              style={`top: calc(${index} * 25rem + 2.25rem);`}
            >
              <div class="flex h-3 w-3 items-center justify-center rounded-full border border-[#071729]/15 bg-white">
                <div class="h-1.5 w-1.5 rounded-full bg-[#0B2C4A]"></div>
              </div>
            </div>
          ))
        }
      </div>

      <div>
        {
          phases.map((phase, index) => (
            <article class:list={['mb-12 md:mb-20', index === phases.length - 1 && 'mb-0']}>
              <div class="relative border-l-2 border-l-[#0B2C4A]/30 p-6 transition-all duration-300 hover:bg-[#F3F8FC] md:border-l-0 md:p-8 lg:p-10">
                <div class="flex items-start gap-6 lg:gap-10">
                  <span class="hidden shrink-0 select-none text-7xl font-extralight leading-[0.85] tracking-[-0.06em] text-[#0B2C4A]/10 lg:block">
                    {phase.number}
                  </span>

                  <div class="flex-1">
                    <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.25em] text-[#0B2C4A]/70">
                      {phase.label}
                    </p>

                    <h3 class="mb-3 text-lg font-medium tracking-[-0.03em] text-[#071729] md:text-xl lg:text-2xl">
                      <span class="mr-2 font-extralight text-[#0B2C4A]/40 lg:hidden">
                        {phase.number}
                      </span>
                      {phase.title}
                    </h3>

                    <p class="max-w-[520px] text-[0.95rem] leading-7 text-[#071729]/65">
                      {phase.text}
                    </p>

                    <span class="mt-5 inline-flex items-center gap-1.5 rounded-full border border-[#0B2C4A]/20 bg-[#0B2C4A]/5 px-3 py-1 text-xs font-medium text-[#0B2C4A]">
                      <span class="h-1 w-1 rounded-full bg-[#0B2C4A]"></span>
                      {phase.badge}
                    </span>
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const initProcessTimeline = () => {
    const section = document.getElementById('process');
    const progress = document.getElementById('process-progress');

    if (!section || !progress) return;

    const updateProgress = () => {
      const rect = section.getBoundingClientRect();
      const viewportHeight = window.innerHeight;

      const start = viewportHeight * 0.65;
      const end = rect.height - viewportHeight * 0.35;

      const current = start - rect.top;
      const progressRatio = Math.min(Math.max(current / end, 0), 1);

      progress.style.height = `${progressRatio * 100}%`;
    };

    updateProgress();

    window.addEventListener('scroll', updateProgress, { passive: true });
    window.addEventListener('resize', updateProgress);
  };

  initProcessTimeline();
  document.addEventListener('astro:page-load', initProcessTimeline);
</script>