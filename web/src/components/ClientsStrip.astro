---
import { clientsContent, type Locale } from '../lib/siteContent';

const { locale = 'es' } = Astro.props;
const content = clientsContent[locale as Locale];

const logos = [
  { name: 'Argenia', logo: '/clients/logo-argenia.png', url: 'https://grupoargenia.com/' },
  { name: 'Area Construcción', logo: '/clients/logo-area.png', url: 'https://www.areaconstruccion.com/' },
  { name: 'Garmel Instalaciones', logo: '/clients/logo-garmel.jpg', url: 'https://garmel.es/' },
];

// 4 repetitions per set so the strip fills any viewport width
const reps = [...logos, ...logos, ...logos, ...logos];
---

<section class="border-t border-[#071729]/10 bg-[#eef4fb] py-14 overflow-hidden">
  <p class="mb-10 text-center text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-[#071729]/35 px-4">
    {content.eyebrow}
  </p>

  <div class="marquee-root">
    <!-- Left fade edge -->
    <div class="fade-left" aria-hidden="true"></div>
    <!-- Right fade edge -->
    <div class="fade-right" aria-hidden="true"></div>

    <div class="marquee-viewport">
      <div class="marquee-track">

        <!-- Set A: real content -->
        {reps.map((client) => (
          <div class="marquee-item">
            <a href={client.url} target="_blank" rel="noopener noreferrer" class="logo-card" aria-label={client.name}>
              <img src={client.logo} alt={client.name} loading="lazy" decoding="async" />
            </a>
          </div>
        ))}

        <!-- Set B: seamless-loop duplicate (hidden from a11y) -->
        {reps.map((client) => (
          <div class="marquee-item" aria-hidden="true">
            <div class="logo-card">
              <img src={client.logo} alt="" loading="lazy" decoding="async" />
            </div>
          </div>
        ))}

      </div>
    </div>
  </div>
</section>

<style>
  /* ── Root container ─────────────────────────────── */
  .marquee-root {
    position: relative;
  }

  /* ── Edge fade masks ────────────────────────────── */
  .fade-left,
  .fade-right {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 10;
    pointer-events: none;
  }
  .fade-left  { left:  0; background: linear-gradient(to right,  #eef4fb, transparent); }
  .fade-right { right: 0; background: linear-gradient(to left, #eef4fb, transparent); }

  /* ── Scrolling viewport ─────────────────────────── */
  .marquee-viewport {
    overflow: hidden;
  }

  /* ── Animated track ─────────────────────────────── */
  .marquee-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: logo-scroll 34s linear infinite;
  }

  /* Pause the scroll when cursor is anywhere on the strip */
  .marquee-viewport:hover .marquee-track {
    animation-play-state: paused;
  }

  /* ── Individual item spacing ────────────────────── */
  .marquee-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 36px;
  }

  /* ── Logo card ──────────────────────────────────── */
  .logo-card {
    text-decoration: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 144px;
    height: 72px;
    background: white;
    border-radius: 14px;
    padding: 10px 14px;
    box-shadow: 0 2px 10px rgba(7, 23, 41, 0.06);
    filter: grayscale(1) opacity(0.42);
    transition: filter 360ms ease, box-shadow 360ms ease, transform 360ms ease;
    will-change: filter;
  }

  .logo-card:hover {
    filter: grayscale(0) opacity(1);
    box-shadow: 0 10px 28px rgba(7, 23, 41, 0.13);
    transform: translateY(-2px);
  }

  .logo-card img {
    display: block;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 6px;
  }

  /* ── Keyframe ───────────────────────────────────── */
  @keyframes logo-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Reduced motion: static centered layout ─────── */
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
      width: auto;
      flex-wrap: wrap;
      justify-content: center;
      gap: 16px;
    }
    /* Hide the duplicate set */
    .marquee-item[aria-hidden="true"] {
      display: none;
    }
    /* From the real set, only show the first N logos (logos.length = 3 × 4 reps = 12;
       we only want the first 3 unique ones) */
    .marquee-item:nth-child(n + 4):not([aria-hidden]) {
      display: none;
    }
    .logo-card {
      filter: none;
    }
  }
</style>
