---
import Layout from '../layouts/Layout.astro';
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<Layout
  title="Asistente IA | Vidra"
  description="Consulta documentación interna con nuestro asistente de inteligencia artificial."
>
  <div class="flex min-h-screen flex-col pt-[5.5rem]">

    <!-- Header -->
    <div class="border-b border-[rgba(7,23,41,0.08)] bg-white px-4 py-4">
      <div class="mx-auto flex max-w-3xl items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#0d3c78]">
          <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-4 4z" />
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-[#071729]">Asistente IA</p>
          <p class="text-xs text-[#071729]/50">Basado en documentación interna</p>
        </div>
      </div>
    </div>

    <!-- Messages -->
    <div id="messages" class="flex-1 overflow-y-auto px-4 py-6">
      <div class="mx-auto max-w-3xl space-y-6">

        <!-- Welcome message -->
        <div class="flex gap-3">
          <div class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#0d3c78]">
            <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-4 4z" />
            </svg>
          </div>
          <div class="max-w-[80%] rounded-2xl rounded-tl-sm bg-white px-4 py-3 shadow-[0_2px_12px_rgba(7,23,41,0.08)]">
            <p class="text-sm leading-relaxed text-[#071729]">
              Hola, soy el asistente de Vidra. Puedo responder preguntas sobre la documentación interna. ¿En qué puedo ayudarte?
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- Input -->
    <div class="border-t border-[rgba(7,23,41,0.08)] bg-white px-4 py-4">
      <form id="chat-form" class="mx-auto flex max-w-3xl gap-3">
        <input
          id="chat-input"
          type="text"
          placeholder="Escribe tu pregunta..."
          autocomplete="off"
          class="flex-1 rounded-xl border border-[rgba(7,23,41,0.12)] bg-[#eef4fb] px-4 py-3 text-sm text-[#071729] outline-none transition placeholder:text-[#071729]/40 focus:border-[#00b2eb] focus:ring-2 focus:ring-[#00b2eb]/20"
        />
        <button
          id="send-btn"
          type="submit"
          class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[#0d3c78] text-white transition hover:bg-[#00b2eb] disabled:opacity-40"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
        </button>
      </form>
    </div>
  </div>
</Layout>

<script is:inline define:vars={{ apiUrl }}>
  const messagesEl = document.getElementById('messages');
  const form = document.getElementById('chat-form');
  const input = document.getElementById('chat-input');
  const sendBtn = document.getElementById('send-btn');

  const container = () => messagesEl.querySelector('.space-y-6');
  const history = []; // { rol: 'usuario'|'asistente', contenido: string }

  function addUserMessage(text) {
    const div = document.createElement('div');
    div.className = 'flex justify-end gap-3';
    div.innerHTML = `
      <div class="max-w-[80%] rounded-2xl rounded-tr-sm bg-[#0d3c78] px-4 py-3">
        <p class="text-sm leading-relaxed text-white">${escapeHtml(text)}</p>
      </div>
    `;
    container().appendChild(div);
    scrollBottom();
    return div;
  }

  function addAssistantMessage(text, sources) {
    const sourcesHtml = '';

    const div = document.createElement('div');
    div.className = 'flex gap-3';
    div.innerHTML = `
      <div class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#0d3c78]">
        <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-4 4z"/>
        </svg>
      </div>
      <div class="max-w-[80%]">
        <div class="rounded-2xl rounded-tl-sm bg-white px-4 py-3 shadow-[0_2px_12px_rgba(7,23,41,0.08)]">
          <p class="text-sm leading-relaxed text-[#071729] whitespace-pre-line">${escapeHtml(text)}</p>
          ${sourcesHtml}
        </div>
      </div>
    `;
    container().appendChild(div);
    scrollBottom();
  }

  function addLoadingMessage() {
    const div = document.createElement('div');
    div.id = 'loading-msg';
    div.className = 'flex gap-3';
    div.innerHTML = `
      <div class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#0d3c78]">
        <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-4 4z"/>
        </svg>
      </div>
      <div class="max-w-[80%] rounded-2xl rounded-tl-sm bg-white px-4 py-3 shadow-[0_2px_12px_rgba(7,23,41,0.08)]">
        <div class="flex gap-1.5 items-center h-5">
          <span class="h-2 w-2 rounded-full bg-[#00b2eb] animate-bounce" style="animation-delay:0ms"></span>
          <span class="h-2 w-2 rounded-full bg-[#00b2eb] animate-bounce" style="animation-delay:150ms"></span>
          <span class="h-2 w-2 rounded-full bg-[#00b2eb] animate-bounce" style="animation-delay:300ms"></span>
        </div>
      </div>
    `;
    container().appendChild(div);
    scrollBottom();
  }

  function removeLoading() {
    document.getElementById('loading-msg')?.remove();
  }

  function scrollBottom() {
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function setLoading(on) {
    sendBtn.disabled = on;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const question = input.value.trim();
    if (!question) return;

    input.value = '';
    input.focus();
    addUserMessage(question);
    setLoading(true);
    addLoadingMessage();

    try {
      const res = await fetch(`${apiUrl}/rag/chat`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ pregunta: question, top_k: 10, historial: history.slice(-10) }),
      });

      if (!res.ok) throw new Error(`Error ${res.status}`);
      const data = await res.json();
      removeLoading();
      addAssistantMessage(data.respuesta, data.fuentes);
      history.push({ rol: 'usuario', contenido: question });
      history.push({ rol: 'asistente', contenido: data.respuesta });
    } catch (err) {
      removeLoading();
      addAssistantMessage('Ha ocurrido un error al conectar con el asistente. Por favor, inténtalo de nuevo.', []);
    } finally {
      setLoading(false);
      input.focus();
    }
  });
</script>
