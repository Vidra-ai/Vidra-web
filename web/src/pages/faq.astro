---
import BaseLayout from "../layouts/Layout.astro";
import { faqContent, type Locale } from "../lib/siteContent";

const locale: Locale = "es";
const content = faqContent[locale];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: content.items.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---

<BaseLayout title={content.title} description={content.description}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />

  <div data-nav-theme="light" class="min-h-screen bg-[#071729] px-4 pb-28 pt-32 md:px-6 md:pt-40">
    <div class="mx-auto max-w-3xl">

      <div class="mb-16">
        <p class="mb-4 text-[0.75rem] font-semibold uppercase tracking-[0.25em] text-[#00b2eb]">
          {content.eyebrow}
        </p>
        <h1 class="text-[clamp(2.4rem,5vw,4.5rem)] font-medium leading-[0.93] tracking-[-0.05em] text-white">
          {content.heading}
        </h1>
        <p class="mt-5 text-[1.05rem] leading-7 text-white/60">
          {content.subheading}
        </p>
      </div>

      <div class="space-y-3">
        {content.items.map((item, i) => (
          <details
            class="group rounded-[1.25rem] border border-white/8 bg-white/3 transition duration-300 open:border-[#00b2eb]/25 open:bg-white/6"
          >
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-7 py-5 select-none">
              <span class="text-[1rem] font-medium leading-snug tracking-[-0.02em] text-white">
                {item.q}
              </span>
              <span class="shrink-0 text-[#00b2eb] transition-transform duration-300 group-open:rotate-45">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                </svg>
              </span>
            </summary>
            <div class="px-7 pb-6">
              <p class="text-[0.95rem] leading-7 text-white/65">
                {item.a}
              </p>
            </div>
          </details>
        ))}
      </div>

      <div class="mt-20 text-center">
        <a
          href={content.ctaHref}
          class="inline-flex items-center gap-3 rounded-full bg-[#00b2eb] px-8 py-4 text-sm font-semibold text-[#071729] transition hover:bg-white"
        >
          {content.cta}
          <span class="text-base">→</span>
        </a>
      </div>

    </div>
  </div>
</BaseLayout>
