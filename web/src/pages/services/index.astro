---
import { Image, getImage } from "astro:assets";
import analysisImage from "../../assets/analysis.jpg";
import machineLearningImage from "../../assets/machine-learning.jpg";
import deepLearningImage from "../../assets/deep-learning.jpg";
import BaseLayout from "../../layouts/Layout.astro";
import { serviceContent, type Locale } from "../../lib/siteContent";

const locale: Locale = Astro.url.pathname.startsWith("/en") ? "en" : "es";
const content = serviceContent[locale];
const services = content.services;
const serviceBase = locale === "en" ? "/en/services" : "/services";
const serviceImages = {
  analysis: analysisImage,
  machineLearning: machineLearningImage,
  deepLearning: deepLearningImage,
} as const;

type ServiceImageKey = keyof typeof serviceImages;

const optimizedServices = await Promise.all(
  services.map(async (service) => {
    const imageKey = service.imageKey as ServiceImageKey;
    const imageAsset = serviceImages[imageKey];

    const optimizedImage = await getImage({
      src: imageAsset,
      width: 520,
      height: 390,
      format: "webp",
      quality: 65,
    });

    return {
      ...service,
      imageSrc: optimizedImage.src,
    };
  })
);
---

<BaseLayout title={`${content.index.eyebrow} | Vidra`} description={content.index.description}>
  <main class="bg-[#eef4fb] pt-24">
    <section class="px-4 py-12 md:px-6 md:py-16">
      <div class="mx-auto max-w-7xl">
        <a
          href={locale === "en" ? "/en/#what-we-do" : "/#what-we-do"}
          class="mb-10 inline-flex items-center gap-2 py-1 text-sm font-medium text-[#0B2C4A]/68 transition hover:text-[#0B2C4A]"
        >
          <span aria-hidden="true">←</span>
          {content.index.backLabel}
        </a>

        <div class="border-t border-[#0B2C4A]/12 pt-10">
          <p class="mb-6 text-[0.875rem] font-semibold uppercase tracking-[0.25em] text-[#00B2EB]">
            {content.index.eyebrow}
          </p>

          <h1 class="max-w-3xl text-[clamp(2rem,4vw,3.2rem)] font-medium leading-[1] tracking-[-0.04em] text-[#0B2C4A]">
            {content.index.title}
          </h1>

          <p class="mt-6 max-w-2xl text-[1.05rem] leading-8 text-[#0B2C4A]/68">
            {content.index.description}
          </p>

          <div class="mt-16 grid gap-5 md:grid-cols-3">
            {optimizedServices.map((service) => (
              <a
                href={`${serviceBase}/${service.slug}`}
                class="group flex min-h-[520px] flex-col overflow-hidden rounded-[1.5rem] border border-[#0B2C4A]/10 bg-white shadow-[0_20px_60px_rgba(11,44,74,0.08)] transition duration-500 hover:-translate-y-2 hover:border-transparent hover:bg-[#0B2C4A]"
              >
                <Image
                  src={service.imageSrc}
                  alt={locale === "en" ? `${service.title} Service - Vidra` : `Servicio de ${service.title} - Vidra`}
                  width={640}
                  height={480}
                  format="webp"
                  quality={72}
                  class="aspect-[4/3] w-full object-cover transition duration-700 group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                />

                <div class="flex flex-1 flex-col justify-between p-7">
                  <div>
                    <p class="text-[0.875rem] font-semibold uppercase tracking-[0.25em] text-[#00B2EB] transition group-hover:text-white/55">
                      {service.eyebrow}
                    </p>

                    <h2 class="mt-6 text-[clamp(1.45rem,2.2vw,1.8rem)] font-medium leading-[1.05] tracking-[-0.035em] text-[#0B2C4A] transition group-hover:text-white">
                      {service.title}
                    </h2>

                    <p class="mt-5 text-[1rem] leading-7 text-[#0B2C4A]/68 transition group-hover:text-white/75">
                      {service.description}
                    </p>

                    <div class="mt-8 space-y-3 border-t border-[#0B2C4A]/10 pt-6 transition group-hover:border-white/10">
                      {service.points.map((point) => (
                        <p class="flex items-start gap-2 text-sm font-medium text-[#0B2C4A]/68 transition group-hover:text-white/75">
                          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[#00B2EB] transition group-hover:bg-white/55" aria-hidden="true"></span>
                          {point}
                        </p>
                      ))}
                    </div>
                  </div>

                  <span class="mt-10 grid h-12 w-12 place-items-center rounded-full bg-[#0B2C4A] text-white transition duration-500 group-hover:bg-[#00B2EB] group-hover:text-[#0B2C4A]">
                    →
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- SERVICIOS ESPECÍFICOS -->
  <section class="bg-[#eef4fb] px-4 py-20 md:px-6 md:py-28">
    <div class="mx-auto max-w-7xl">
      <div class="mb-12">
        <p class="mb-4 text-[0.75rem] font-semibold uppercase tracking-[0.25em] text-[#0d3c78]">
          {locale === 'en' ? 'AI capabilities' : 'Capacidades IA'}
        </p>
        <h2 class="max-w-2xl text-[clamp(1.8rem,3.5vw,3rem)] font-medium leading-[0.97] tracking-[-0.04em] text-[#071729]">
          {locale === 'en' ? 'What we actually build.' : 'Lo que construimos, en concreto.'}
        </h2>
      </div>

      <div class="grid gap-px bg-[#071729]/8 overflow-hidden rounded-[1.5rem] sm:grid-cols-2 lg:grid-cols-4">
        {[
          {
            num: locale === 'en' ? 'ML · 01' : 'ML · 01',
            title: locale === 'en' ? 'Predictive models' : 'Modelos predictivos',
            desc: locale === 'en' ? 'Demand forecasting, anomaly detection, cost estimation. Trained on your historical data.' : 'Previsión de demanda, detección de anomalías, estimación de costes. Entrenados con tus datos históricos.',
            tags: ['scikit-learn', 'XGBoost', 'CatBoost', 'LSTM'],
          },
          {
            num: locale === 'en' ? 'LLM · 02' : 'LLM · 02',
            title: locale === 'en' ? 'RAG chatbots' : 'Chatbots RAG',
            desc: locale === 'en' ? 'Q&A systems over your own documents, manuals, or knowledge base. Deployed with your data, not public.' : 'Sistemas de preguntas sobre tu propia documentación, manuales o base de conocimiento. Con tus datos, no los públicos.',
            tags: ['OpenAI', 'pgvector', 'FastAPI'],
          },
          {
            num: locale === 'en' ? 'App · 03' : 'App · 03',
            title: locale === 'en' ? 'AI hubs for enterprise' : 'Hubs IA para empresa',
            desc: locale === 'en' ? 'Modular platforms that group AI tools by department. Each new capability is a registry entry, not a rewrite.' : 'Plataformas modulares que agrupan herramientas de IA por departamento. Cada nueva capacidad es una entrada en el registro, no una reescritura.',
            tags: ['React + Vite', 'Electron', 'Docker'],
          },
          {
            num: locale === 'en' ? 'AI · 04' : 'IA · 04',
            title: locale === 'en' ? 'Agentic pipelines' : 'Pipelines agénticos',
            desc: locale === 'en' ? 'Automated multi-agent flows for market intelligence, document processing, or business monitoring.' : 'Flujos multi-agente automáticos para inteligencia de mercado, procesamiento de documentos o monitorización de negocio.',
            tags: ['Gemini AI', 'Python', 'Pydantic'],
          },
        ].map((item) => (
          <div class="bg-white p-7 transition hover:bg-[#eef4fb]">
            <p class="mb-4 text-[0.7rem] font-bold uppercase tracking-[0.2em] text-[#00b2eb]">{item.num}</p>
            <h3 class="mb-3 text-[1.05rem] font-semibold text-[#071729]">{item.title}</h3>
            <p class="mb-5 text-[0.88rem] leading-6 text-[#071729]/60">{item.desc}</p>
            <div class="flex flex-wrap gap-1.5">
              {item.tags.map((tag) => (
                <span class="rounded-full border border-[#071729]/10 px-2.5 py-1 text-[0.68rem] font-medium text-[#071729]/50">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>