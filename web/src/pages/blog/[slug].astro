---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { blogPageContent, type Locale } from '../../lib/siteContent';

export async function getStaticPaths() {
  const esPosts = await getCollection('blog', ({ data }) => data.lang === 'es');
  const enPosts = await getCollection('blog', ({ data }) => data.lang === 'en');

  return esPosts.map((post) => {
    const slug = post.id.replace(/\.md$/, '');
    let enAlternateSlug: string | null = null;
    if (post.data.translationKey) {
      const match = enPosts.find((p) => p.data.translationKey === post.data.translationKey);
      if (match) enAlternateSlug = match.id.replace(/\.md$/, '');
    }
    return { params: { slug }, props: { post, enAlternateSlug } };
  });
}

const { post, enAlternateSlug } = Astro.props;
const { Content } = await render(post);

const { title, description, pubDate, category, image, lang } = post.data;
const locale = lang as Locale;
const t = blogPageContent[locale];
const backHref = '/blog/';
const dateLocale = 'es-ES';
const slug = post.id.replace(/\.md$/, '');

const siteOrigin = 'https://vidra-ia.com';
const canonicalUrl = `${siteOrigin}/blog/${slug}`;
const absoluteImage = image ? new URL(image, Astro.url).toString() : undefined;

const postAlternates = enAlternateSlug
  ? [
      { hreflang: 'es', href: canonicalUrl },
      { hreflang: 'en', href: `${siteOrigin}/en/blog/${enAlternateSlug}` },
      { hreflang: 'x-default', href: canonicalUrl },
    ]
  : [];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
  "headline": title,
  "description": description,
  "image": absoluteImage,
  "datePublished": pubDate.toISOString(),
  "inLanguage": "es-ES",
  "author": { "@type": "Organization", "name": "Vidra", "url": siteOrigin },
  "publisher": {
    "@type": "Organization",
    "name": "Vidra",
    "url": siteOrigin,
    "logo": { "@type": "ImageObject", "url": `${siteOrigin}/favicon.svg` },
  },
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteOrigin}/` },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${siteOrigin}/blog` },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonicalUrl },
  ],
};
---

<Layout
  title={`${title} | Vidra`}
  description={description}
  ogImage={image}
  ogType="article"
  alternates={postAlternates}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <article class="relative px-4 pb-24 pt-24 md:px-6 md:pt-32">
    <div class="mx-auto max-w-4xl">
      <a href={backHref} class="mb-10 inline-block text-sm font-bold uppercase tracking-widest text-ink/40 transition hover:text-blue">
        ← {t.backToBlog}
      </a>

      <header class="mb-12">
        <div class="mb-6 flex items-center gap-4">
          <span class="rounded-full bg-blue px-4 py-1.5 text-[10px] font-bold uppercase tracking-[0.15em] text-ink">
            {t.categories[category]}
          </span>

          <time class="text-xs font-medium uppercase tracking-widest text-black/40">
            {new Intl.DateTimeFormat(dateLocale, { dateStyle: 'long' }).format(pubDate)}
          </time>
        </div>

        <h1 class="mb-8 text-3xl font-bold leading-[1.1] text-ink md:text-5xl">
          {title}
        </h1>

        <p class="max-w-3xl text-xl leading-relaxed text-ink/70">
          {description}
        </p>
      </header>

      {image && (
        <div class="mb-16 aspect-video overflow-hidden rounded-3xl shadow-2xl shadow-blue/5">
          <Image
            src={image}
            alt={title}
            width={1200}
            height={675}
            loading="eager"
            class="h-full w-full object-cover"
          />
        </div>
      )}

      <div class="prose prose-lg mx-auto max-w-none prose-headings:font-bold prose-headings:text-ink prose-a:text-blue prose-img:rounded-2xl">
        <Content />
      </div>

      <!-- B2B Conversion Block -->
      <div class="mt-24 rounded-[2rem] bg-[#0B2C4A] p-8 text-white shadow-[0_28px_90px_rgba(11,44,74,0.15)] md:p-12">
        <div class="max-w-2xl">
          <h2 class="mb-4 text-2xl font-bold leading-tight tracking-tight md:text-3xl">
            {t.ctaBlock.title}
          </h2>
          <p class="mb-8 text-lg text-white/80">
            {t.ctaBlock.description}
          </p>
          <a href={locale === 'en' ? '/en/#contact' : '/#contact'} class="inline-flex items-center gap-3 rounded-full bg-white px-8 py-4 text-sm font-bold uppercase tracking-widest text-[#0B2C4A] transition-all hover:bg-blue hover:text-ink hover:scale-105">
            {t.ctaBlock.cta} <span class="text-xl">→</span>
          </a>
        </div>
      </div>
    </div>
  </article>
</Layout>