# Copia a .env y rellena. Los valores REALES van en Vaultwarden (ver Obsidian:
# "Gestión de secretos"), nunca commiteados. .env está en .gitignore.

# Base de datos
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=chatbot

# LLM (clave en Vaultwarden: 03 - Proveedores IA)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small

# Clave de admin para endpoints protegidos (/rag/documents, /rag/sources, /rag/sync)
# (Vaultwarden: 01 - Servidor Vidra)
ADMIN_API_KEY=

# Orígenes CORS permitidos (separados por comas).
# Local: http://localhost:4322,http://localhost:4321
# Producción: https://vidra-ia.com
CORS_ORIGINS=http://localhost:4322,http://localhost:4321

# URL de la API accesible desde el navegador (la usa la web Astro en build time)
# Local: http://localhost:8001 — Producción: https://<subdominio-api>.vidra-ia.com
PUBLIC_API_URL=http://localhost:8001

# --- Solo producción (docker-compose.prod.yml) ---
# Imagen de la API en GHCR (deja el default salvo que cambie el repo)
# CHATBOT_API_IMAGE=ghcr.io/vidra-ai/vidra-web-chatbot:latest
# Workers de uvicorn (1 recomendado; >1 requiere mover el rate limit a Redis)
# UVICORN_WORKERS=1
