# Copia a .env y rellena. Los valores REALES van en Vaultwarden (ver Obsidian:
# "Gestión de secretos"), nunca commiteados. .env está en .gitignore.

# Base de datos
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=chatbot

# LLM (clave en Vaultwarden: 03 - Proveedores IA)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small

# Clave de admin para endpoints protegidos (/rag/documents, /rag/sources, /rag/sync)
# (Vaultwarden: 01 - Servidor Vidra)
ADMIN_API_KEY=

# Trazabilidad centralizada en vidra_api_core (registro de tasks + usage del chatbot).
# Vacío = desactivado (falla en silencio, no bloquea el chat). Local: requiere que
# vidra_api_core esté corriendo y conectado a la red externa "vidra_internal".
VIDRA_API_URL=http://vidra_api_core:8000
VIDRA_API_KEY=

# Orígenes CORS permitidos (separados por comas).
# Local: http://localhost:4322,http://localhost:4321
# Producción: https://vidra-ia.com (mismo origen, CORS no es estrictamente necesario)
CORS_ORIGINS=http://localhost:4322,http://localhost:4321

# Documentación interactiva de la API (/docs, /redoc, /openapi.json).
# ⚠️ Mantener en false en producción. Solo activar en entorno local para desarrollo.
API_DOCS_ENABLED=false

# URL de la API accesible desde el navegador (la usa la web Astro en build time)
# Local: http://localhost:8001 — Producción: https://vidra-ia.com/api
PUBLIC_API_URL=http://localhost:8001

# Carpeta "Información pública" del vault Obsidian (fuente del chatbot).
# El backend la lee montada en /vault-publico y re-embebe solo los .md que cambian.
# PUBLIC_DOCS_HOST_DIR = ruta en el HOST que se monta como volumen.
# Local (MEGA): C:/Users/CDiaz/Desktop/MEGA/Vidra-docs/Obsidian-Vidra/01 - Información pública (web - chatbot)
PUBLIC_DOCS_HOST_DIR=C:/Users/CDiaz/Desktop/MEGA/Vidra-docs/Obsidian-Vidra/01 - Información pública (web - chatbot)
PUBLIC_DOCS_SYNC_INTERVAL=10
# Si true, solo se indexan notas con frontmatter `visibilidad: publico` (ADR-005)
PUBLIC_DOCS_REQUIRE_PUBLIC_FLAG=true

# --- Solo producción (docker-compose.prod.yml) ---
# Imagen de la API en GHCR (deja el default salvo que cambie el repo)
# CHATBOT_API_IMAGE=ghcr.io/vidra-ai/vidra-web-chatbot:latest
# Workers de uvicorn (1 recomendado; >1 requiere mover el rate limit a Redis)
# UVICORN_WORKERS=1

# =====================================================================
# Motor de contenido (backend/app/content): genera un artículo de blog
# y autopostea en LinkedIn. Uso LOCAL (escribe en el repo y luego commit).
#   cd backend
#   python -m app.content run --tenant vidra-ia --dry-run
#   python -m app.content run --tenant vidra-ia --no-dry-run --limit 1
# =====================================================================

# Claves DEDICADAS del motor (proyectos separados del chatbot para medir el gasto
# por parte). Sin fallback a las claves del chatbot: si están vacías, el motor no
# genera. Crea claves nuevas en proyectos propios (Anthropic + OpenAI) y pégalas.
CONTENT_ANTHROPIC_API_KEY=   # texto: redacción + evaluación + post LinkedIn + prompt de imagen
CONTENT_OPENAI_API_KEY=      # imagen de cabecera (gpt-image)
CONTENT_LLM_MODEL=claude-sonnet-4-6

# --- LinkedIn (autopost) ---
# ⚠️ PENDIENTE: la publicación en LinkedIn NO está operativa todavía (token / aprobación
#   de la Community Management API). El motor genera igualmente el texto del post en
#   backend/content_output/<slug>.linkedin.txt para publicarlo a mano.
# Para (re)generar el token cuando esté desbloqueado: python backend/scripts/linkedin_auth.py
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_TOKEN_EXPIRES_AT=
LINKEDIN_AUTHOR_URN=urn:li:organization:XXXXXX
CLIENT_ID=
CLIENT_SECRET=

# --- Rutas del motor de contenido (opcionales; por defecto se calculan respecto al repo) ---
# CONTENT_BLOG_DIR=        # destino del .md (def: web/src/content/blog)
# CONTENT_IMAGE_DIR=       # destino de la imagen (def: web/public/images/blog)
# CONTENT_IMAGE_PUBLIC_BASE=/images/blog
# CONTENT_OUTPUT_DIR=      # JSON + histórico + textos sociales (def: backend/content_output)
# CONTENT_TENANTS_DIR=     # YAML de tenants (def: backend/config/tenants)
# CONTENT_LOG_LEVEL=INFO
